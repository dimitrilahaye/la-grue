# URL de connexion runtime (pooler PgBouncer, port 6543 sur Supabase)
DATABASE_URL=postgresql://lagrue:lagrue@localhost:5433/lagrue

# URL de connexion directe pour les migrations Drizzle (port 5432)
# Sur Supabase : utiliser la connexion directe (pas le pooler)
MIGRATION_DATABASE_URL=postgresql://lagrue:lagrue@localhost:5433/lagrue

# Secret partagé entre le Web Service Render et le Cron Job Render
CRON_SECRET=change-me-in-production

# Port du serveur Express (défaut 3000)
PORT=3000

# Origine autorisée pour CORS (en production, mettre l'URL Render du Web Service)
ALLOWED_ORIGIN=http://localhost:3000
